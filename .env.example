# ═══════════════════════════════════════════════════════════════
# .env — Bug Bounty Automation API
# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git!
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here   # dari Settings > API > service_role

# ─── AI Provider ────────────────────────────────────────────────
# Nilai: claude | openai | ollama
# Bisa diganti runtime via POST /api/ai/switch
AI_PROVIDER=claude

# Claude (Anthropic) — akun pribadi
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI — akun kantor / klien
# Jika kantor pakai proxy OpenAI-compatible, ganti OPENAI_BASE_URL
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
# Contoh proxy kantor: OPENAI_BASE_URL=https://ai.perusahaan.com/v1

# Ollama — lokal / self-hosted (tidak butuh API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Batas penggunaan AI (penting! jaga agar tidak boros token) ─
AI_MAX_TOKENS=1000               # token per request AI
AI_MAX_FINDINGS_PER_CALL=10     # max temuan yang dikirim ke AI sekaligus

# ─── App ────────────────────────────────────────────────────────
SECRET_KEY=ganti-dengan-string-acak-panjang
DEBUG=false
