# ═══════════════════════════════════════════════════════════════
# .env — Bug Bounty Automation API
# Salin ke .env dan isi nilainya. JANGAN commit .env ke git!
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ─── AI Provider ────────────────────────────────────────────────
# Default: gemini (gratis). Bisa diganti runtime via POST /api/ai/switch
AI_PROVIDER=gemini

# Gemini — ambil dari: aistudio.google.com → Get API Key (GRATIS)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Claude (Anthropic) — opsional, berbayar
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI / proxy kantor — opsional
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama — opsional, untuk mode offline/lokal
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Batas penggunaan AI ────────────────────────────────────────
# Gemini free: 1500 req/hari, 1 juta token/menit
AI_MAX_TOKENS=1000
AI_MAX_FINDINGS_PER_CALL=10

# ─── App ────────────────────────────────────────────────────────
SECRET_KEY=isi-string-acak-panjang-bebas
DEBUG=false
